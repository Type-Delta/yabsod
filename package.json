{
  "name": "yabsod",
  "version": "0.0.1",
  "description": "Your Windows machine keeps blue screening? YABSOD is here to embrace it, shows you cool graphs so you can flex with friends, feel a bit better while waiting for a fix. ",
  "homepage": "https://github.com/Type-Delta/yabsod#readme",
  "bugs": {
    "url": "https://github.com/Type-Delta/yabsod/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Type-Delta/yabsod.git"
  },
  "type": "module",
  "license": "MIT",
  "author": "Type-Delta",
  "main": "dist/index.js",
  "bin": {
    "yabsod": "scripts/launcher.cjs"
  },
  "files": [
    "dist/*.js",
    "scripts/postinstall.cjs",
    "scripts/launcher.cjs",
    "resources/bugcheck-reference.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare-dev": "bun i && bun run transpile-esm",
    "start": "bun run src/index.ts",
    "start:node": "tsx src/index.ts",
    "transpile-esm": "bunx tsc -p lib/tsconfig.json && bun run scripts/transform-tools.mjs",
    "check": "bun run ts-check && bun run lint && bun run build",
    "lint": "bun run ts-check && eslint src test scripts --ext .ts -c eslint.config.ts --fix",
    "build": "bun run transpile-esm && bun build ./src/index.ts --outdir=./dist --target=node --format=esm --production --keep-names",
    "ts-check": "bunx tsc --noEmit",
    "package:node": "bun run build",
    "prepack": "bun run package:node",
    "postinstall": "node scripts/postinstall.cjs",
    "scrape:bugchecks": "bun run scripts/scrape-bugchecks.ts",
    "prettier": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"./*.md\"",
    "test": "bun test"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.27",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.4",
    "@types/chai": "^5.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "bun-types": "latest",
    "chai": "^6.2.2",
    "eslint": "^10.0.3",
    "execa": "^9.6.1",
    "jiti": "^2.6.1",
    "linkedom": "^0.18.12",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
